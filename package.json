{
  "name": "communion",
  "version": "0.1.0",
  "private": true,
  "description": "Contained multi-model civilization simulator with a 3D world dashboard.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c auto \"tsx watch server/index.ts\" \"vite --host 0.0.0.0\"",
    "start": "tsx server/index.ts",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test server/tests/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
